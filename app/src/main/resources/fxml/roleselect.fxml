<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="741.0" prefWidth="1024.0" spacing="16.0" stylesheets="@../style/start.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unicam.cs.mpgc.rpg126599.controller.RoleSelectController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>
    <children>
        <Label prefHeight="66.0" prefWidth="473.0" styleClass="title" text="SHADOW PLAY" />
        <Label styleClass="subtitle" text="Scegli il tuo ruolo" />
        <Button fx:id="killerButton" onAction="#onChooseKiller" prefHeight="42.0" prefWidth="340.0" text="Gioca come Killer" />
        <Button fx:id="policeButton" onAction="#onChoosePolice" prefHeight="42.0" prefWidth="338.0" text="Gioca come Poliziotto" />
        <Button onAction="#onLoadGame" prefHeight="42.0" prefWidth="335.0" text="Carica partita salvata" />
        <Label fx:id="messageLabel" style="-fx-text-fill: #aa3333;" wrapText="true" />
    </children>
</VBox>
